# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# The "from" address for outgoing emails.
# Must be from a domain you've verified in Resend.
# During testing you can leave this unset and it will use onboarding@resend.dev
RESEND_FROM_EMAIL=Portfolio Contact Form <contact@yourdomain.com>
